{
    $schema: "https://docs.renovatebot.com/renovate-schema.json",
    extends: [
        "config:recommended",
        "docker:enableMajor",
        "helpers:pinGitHubActionDigests",
        ":automergeBranch",
        ":disableRateLimiting",
        ":dependencyDashboard",
        ":semanticCommits",
        ":timezone(Europe/Oslo)",
    ],
    dependencyDashboardTitle: "Renovate Dashboard 🤖",
    suppressNotifications: [
        "prEditedNotification",
        "prIgnoreNotification",
    ],
    lockFileMaintenance: {
        enabled: true,
        automerge: true,
        automergeType: "branch",
        ignoreTests: true,
        schedule: [
            "at any time"
        ],
    },
    nix: {
        enabled: true,
    },
    packageRules: [
        {
            matchDatasources: [
                "docker"
            ],
            automerge: true,
            automergeType: "branch",
            matchUpdateTypes: [
                "digest"
            ],
        },
    ],
}