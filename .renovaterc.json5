{
    $schema: "https://docs.renovatebot.com/renovate-schema.json",
    extends: [
        "config:recommended",
        ":timezone(Europe/Oslo)",
    ],
    dependencyDashboardTitle: "Renovate Dashboard 🤖",
    lockFileMaintenance: {
        enabled: true,
        automerge: true,
        automergeType: "branch",
        ignoreTests: true,
        schedule: [
            "at any time"
        ],
    },
    nix: {
        enabled: true,
    },
    packageRules: [
        {
            // GitHub Actions: automerge
            matchManagers: [
                "github-actions"
            ],
            automerge: true,
            automergeType: "pr",
            labels: [
                "dependencies",
                "github-actions"
            ],
        },
    ],
}